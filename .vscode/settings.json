{
  "cosmic-ai.defaultEnvManager": "ms-python.python:system",
  "cosmic-ai.pythonProjects": [],
  "editor.fontFamily": "'Cascadia Code', 'Fira Code', monospace",
  "editor.fontSize": 14,
  "editor.lineNumbers": "on",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.rulers": [
    80,
    120
  ],
  "editor.bracketPairColorization.enabled": true,
  "editor.stickyScroll.enabled": false,
  "editor.dragAndDrop": true,
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "workbench.colorTheme": "GitHub Dark Dimmed",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.list.openMode": "singleClick",
  "workbench.editor.openPositioning": "right",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "'Cascadia Mono', monospace",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorWidth": 1,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.rightClickBehavior": "paste",
  "terminal.integrated.rightClickCopyPaste": true,
  "terminal.integrated.gpuAcceleration": "on",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "explorer.confirmDelete": false,
  "explorer.compactFolders": true,
  "typescript.suggest.paths": false,
  "javascript.suggest.paths": false,
  "python.defaultInterpreterPath": "python",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.extraPaths": [
    "./src"
  ],
  "python.testing.pytestEnabled": true,
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "C_Cpp.default.intelliSenseMode": "${default}",
  "autoBarrel.defaultLanguage": "typescript",
  "autoBarrel.watchGlob": "**/src/**/*.{ts,tsx,js,jsx,vue}",
  "autoBarrel.ignoreFilePathContainingAnyOf": ".spec,.test",
  "extensions.ignoreRecommendations": false,
  "extensions.autoUpdate": true,
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  "[css]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[html]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  }
}
