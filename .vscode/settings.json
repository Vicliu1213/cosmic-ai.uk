{
  "workbench.colorTheme": "Tokyo Nighter",
  "workbench.iconTheme": "azir-buddha-vira-carbon",
  "workbench.productIconTheme": "fluent-icons",
  "window.titleBarStyle": "custom",
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}",
  "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', Consolas, 'Microsoft YaHei', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "window.zoomLevel": 0,
  "window.autoDetectColorScheme": true,
  "window.restoreWindows": "all",
  "window.commandCenter": true,
  "activityBar.visible": true,
  "sideBar.location": "left",
  "workbench.sideBar.location": "left",
  "workbench.statusBar.visible": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 500,
  "files.autoSaveWhenNoErrors": true,
  "files.hotExit": "onExitAndWindowClose",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.organizeImports": "always",
    "source.fixAll.eslint": "always",
    "source.fixAll.ruff": "always"
  },
  "editor.quickSuggestions": {
    "other": "inline",
    "comments": "inline",
    "strings": "inline"
  },
  "editor.quickSuggestionsDelay": 10,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.localityBonus": true,
  "editor.suggest.selectionMode": "always",
  "editor.suggestSelection": "first",
  "editor.suggest.shareSuggestSelections": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingQuotes": "always",
  "editor.autoClosingDelete": "always",
  "editor.autoClosingOvertype": "always",
  "editor.autoSurround": "languageDefined",
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": "active",
  "editor.guides.highlightActiveBracketPair": true,
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentGuide": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.mouseWheelZoom": true,
  "editor.scrollBeyondLastLine": false,
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.showSlider": "always",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.occurrencesHighlight": "singleFile",
  "editor.selectionHighlight": true,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.dragAndDrop": true,
  "editor.emptySelectionClipboard": true,
  "editor.folding": true,
  "editor.foldingHighlight": true,
  "editor.foldingStrategy": "auto",
  "editor.showFoldingControls": "always",
  "editor.hideCursorInOverviewRuler": true,
  "editor.matchBrackets": "always",
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "selection",
  "editor.rulers": [
    88,
    120
  ],
  "editor.tabCompletion": "on",
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 88,
  "editor.wrappingIndent": "same",
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?，。；：「」『』、？",
  "editor.tokenColorCustomizations": {
    "comments": "#6A9955",
    "functions": "#DCDCAA",
    "strings": "#CE9178",
    "keywords": "#C586C0",
    "variables": "#9CDCFE",
    "numbers": "#B5CEA8"
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.venvPath": "${workspaceFolder}/.venv",
  "python.languageServer": "Jedi",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.indexing": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/src",
    "${workspaceFolder}/lib",
    "${workspaceFolder}/data",
    "${workspaceFolder}/engine",
    "${workspaceFolder}/dashboard"
  ],
  "python.analysis.autoSearchPaths": true,
  "python.linting.enabled": true,
  "python.linting.ruffEnabled": true,
  "python.linting.lintOnSave": true,
  "ruff.lint.args": [
    "--fix"
  ],
  "ruff.format.args": [
    "--line-length=88"
  ],
  "ruff.organizeImports": true,
  "ruff.fixAll": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true
  },
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "-v",
    "--tb=short",
    "--cov=.",
    "--cov-report=html",
    "--cov-report=term"
  ],
  "terminal.integrated.fontFamily": "monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.rightClickBehavior": "paste",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.defaultLocation": "editor",
  "terminal.integrated.env.linux": {
    "PYTHONPATH": "${workspaceFolder}",
    "RAY_memory": "2000000000"
  },
  "terminal.integrated.persistentSessionReviveProcess": "onExit",
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.showActiveTerminal": "always",
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.postCommitCommand": "sync",
  "git.pruneOnFetch": true,
  "gitlens.currentLine.enabled": true,
  "gitlens.codeLens.enabled": true,
  "gitlens.hovers.currentLine.over": "line",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.editor.enablePreview": true,
  "workbench.startupEditor": "none",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 12,
  "workbench.editor.wrapTabs": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.showTabs": "single",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.coverage": true,
    "**/htmlcov": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.ray": true,
    "**/.wandb": true
  },
  "errorLens.enabled": true,
  "errorLens.fontStyle": "italic",
  "errorLens.gutterIconsEnabled": true,
  "errorLens.messageBackgroundMode": "message",
  "cSpell.enabled": true,
  "cSpell.language": "en,zh-CN",
  "cSpell.ignoreWords": [
    "pycache",
    "pytest",
    "localhost",
    "datetime",
    "asyncio",
    "Bitget",
    "backtest",
    "backtester",
    "backtesting",
    "algo",
    "datafeed",
    "orderbook",
    "OHLCV",
    "sharpe",
    "maxdrawdown"
  ],
  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  "extensions.ignoreRecommendations": false,
  "extensions.supportUntrustedWorkspaces": true,
  "search.smartCase": true,
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.showLineNumbers": true,
  "search.collapseResults": "alwaysCollapse",
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.venv": true,
    "**/dist": true,
    "**/build": true,
    "**/.ray": true,
    "**/backtest_results": true
  },
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "on",
  "breadcrumbs.showArrays": true,
  "breadcrumbs.showClasses": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.ray/**": true
  },
  "files.associations": {
    "*.py": "python",
    "*.ipynb": "python",
    "requirements*.txt": "python",
    "pyproject.toml": "toml",
    "*.yaml": "yaml",
    "*.yml": "yaml",
    "*.json": "json",
    "*.config": "json",
    "*.strategy": "python"
  },
  "debug.toolBarLocation": "docked",
  "debug.internalConsoleOptions": "neverOpen",
  "debug.showInStatusBar": "always",
  "workbench.colorCustomizations": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#c0caf5",
    "editor.lineHighlightBackground": "#2d2d3a",
    "editor.selectionBackground": "#3d3d4d",
    "sideBar.background": "#181825",
    "sideBar.foreground": "#bac2de",
    "statusBar.background": "#1e1e2e",
    "statusBar.foreground": "#cdd6f4",
    "activityBar.background": "#181825",
    "activityBar.foreground": "#cdd6f4",
    "panel.background": "#181825",
    "panel.border": "#11111b",
    "panelTitle.activeForeground": "#cdd6f4",
    "panelTitle.inactiveForeground": "#7f849c"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": true
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.showToolbar": "always",
  "emmet.includeLanguages": {
    "vue": "html",
    "python": "html"
  },
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "HACK",
    "BUG",
    "NOTE",
    "OPTIMIZE",
    "BACKTEST",
    "STRATEGY"
  ],
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#ffffff",
    "background": "#ff6b6b",
    "icon": "check",
    "iconColor": "#ff6b6b"
  },
  "better-comments.highlightPlainText": true,
  "better-comments.multilineComments": true,
  "indent-rainbow.colors": [
    "rgba(255,0,0,0.1)",
    "rgba(255,127,0,0.1)",
    "rgba(255,255,0,0.1)",
    "rgba(127,255,0,0.1)",
    "rgba(0,255,0,0.1)",
    "rgba(0,255,127,0.1)",
    "rgba(0,255,255,0.1)",
    "rgba(0,127,255,0.1)"
  ],
  "color-highlight.markerType": "dot-before",
  "color-highlight.enable": true,
  "sync.gist": "",
  "sync.autoDownload": true,
  "sync.autoUpload": true,
  "sync.quietSync": true,
  "security.workspace.trust.enabled": false,
  "telemetry.telemetryLevel": "off",
  "files.encoding": "utf8",
  "files.autoGuessEncoding": true
}
