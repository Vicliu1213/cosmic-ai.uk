{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dashboard | 儀表板",
      "description": "Open Dashboard | 開啟儀表板",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/logging_dashboard.py"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Dashboard"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^([^:]*):([^:]*):([^:]*)(.*)$",
          "file": 1,
          "location": 2,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Server is running.*"
        }
      }
    },
    {
      "label": "Upload Plugin | 上傳插件",
      "description": "Launch Upload File Handler | 啟動檔案上傳處理",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/launch_upload.sh"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Plugins"
      },
      "problemMatcher": []
    },
    {
      "label": "Persistent System | 持久系統",
      "description": "Start Persistent System (7-window tmux) | 啟動持久系統",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/start_persistent_system.sh"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "System"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Quantum Algorithm Test | 量子演算法測試",
      "description": "Run Quantum Grover Algorithm Tests | 執行量子 Grover 演算法測試",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["${workspaceFolder}/quantum_grover_trading_algorithm.py"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Testing"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Run Current File | 執行當前檔案",
      "description": "Run currently open Python file | 執行目前開啟的 Python 檔案",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["${file}"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Python"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "Python: Debug Current File | 除錯當前檔案",
      "description": "Debug currently open Python file | 除錯目前開啟的 Python 檔案",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["-m", "pdb", "${file}"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Python"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "pytest: Run All Tests | 執行所有測試",
      "description": "Run all pytest tests | 執行所有 pytest 測試",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/pytest",
      "args": [
        "-v",
        "--tb=short",
        "--cov=.",
        "--cov-report=html",
        "--cov-report=term"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Testing"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "pytest: Run Current Test File | 執行目前測試檔案",
      "description": "Run current test file | 執行目前測試檔案",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/pytest",
      "args": [
        "${file}",
        "-v",
        "--tb=short"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Testing"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "Ruff: Format & Lint | 格式化與檢查",
      "description": "Format and lint Python files with Ruff | 使用 Ruff 格式化和檢查 Python 檔案",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/ruff",
      "args": ["check", "--fix", "."],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Linting"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: Status | 版本控制狀態",
      "description": "Show git status | 顯示 git 狀態",
      "type": "shell",
      "command": "git",
      "args": ["status"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Git"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: Pull Latest | 拉取最新",
      "description": "Pull latest from remote | 從遠端拉取最新",
      "type": "shell",
      "command": "git",
      "args": ["pull", "origin", "main"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Git"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: Commit & Push | 提交並推送",
      "description": "Commit all changes and push to remote | 提交所有變更並推送到遠端",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "git add . && git commit -m 'Update' && git push origin main"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Git"
      },
      "problemMatcher": []
    },
    {
      "label": "System: Health Check | 系統健康檢查",
      "description": "Run system health check | 執行系統健康檢查",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/health-check.sh"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "System"
      },
      "problemMatcher": []
    },
    {
      "label": "System: Live Path | 實時路徑",
      "description": "Show live path status | 顯示實時路徑狀態",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/live-path.sh"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "System"
      },
      "problemMatcher": []
    },
    {
      "label": "System: Metrics | 系統指標",
      "description": "Show real-time metrics | 顯示實時指標",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "watch -n 1 '${workspaceFolder}/scripts/metrics.sh'"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "System"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Docker: Build Image | Docker 建置映像",
      "description": "Build Docker image | 建置 Docker 映像",
      "type": "shell",
      "command": "docker",
      "args": [
        "build",
        "-t",
        "comic-ai:latest",
        "."
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Docker"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Run Container | Docker 執行容器",
      "description": "Run Docker container | 執行 Docker 容器",
      "type": "shell",
      "command": "docker",
      "args": [
        "run",
        "-it",
        "-p",
        "8080:8080",
        "-p",
        "5000:5000",
        "comic-ai:latest"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Docker"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Node: Install Dependencies | Node 安裝依賴",
      "description": "Install Node.js dependencies | 安裝 Node.js 依賴",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Node"
      },
      "problemMatcher": []
    },
    {
      "label": "Node: Run Dev Server | Node 執行開發伺服器",
      "description": "Run Node development server | 執行 Node 開發伺服器",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Node"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Python: Create Virtual Environment | 建立虛擬環境",
      "description": "Create Python virtual environment | 建立 Python 虛擬環境",
      "type": "shell",
      "command": "python",
      "args": ["-m", "venv", "${workspaceFolder}/venv"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Python"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Install Requirements | 安裝依賴",
      "description": "Install Python requirements | 安裝 Python 依賴",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/pip",
      "args": ["install", "-r", "${workspaceFolder}/requirements.txt"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Python"
      },
      "problemMatcher": []
    },
    {
      "label": "Terminal: Open at Root | 在根目錄開啟終端",
      "description": "Open terminal at workspace root | 在工作區根目錄開啟終端",
      "type": "shell",
      "command": "bash",
      "args": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "Terminal"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "CLI: Run Main CLI | 執行主 CLI",
      "description": "Run main CLI interface | 執行主 CLI 介面",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["${workspaceFolder}/src/cli/cli.py"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "CLI"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: Task Panel | 工作面板",
      "description": "Launch Task Panel | 啟動工作面板",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["${workspaceFolder}/task_panel_optimized.py"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "CLI"
      },
      "problemMatcher": []
    },
    {
      "label": "Documentation: Generate Report | 生成報告",
      "description": "Generate session completion report | 生成會話完成報告",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["${workspaceFolder}/SESSION_COMPLETION_REPORT.py"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "Documentation"
      },
      "problemMatcher": []
    }
  ]
}
