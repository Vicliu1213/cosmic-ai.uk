{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-ai.uk/schemas/immortal_perpetual_schema.json",
  "title": "Immortal Perpetual Agent Contract",
  "description": "Schema for durable Hermes agent runtime, governance, verification, and skill mesh state.",
  "type": "object",
  "required": [
    "identity",
    "runtime",
    "governance",
    "verification"
  ],
  "properties": {
    "identity": {
      "type": "object",
      "required": [
        "name",
        "mode",
        "objective"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "passive",
            "active",
            "hybrid",
            "hybrid-absolute"
          ]
        },
        "objective": {
          "type": "string"
        },
        "persona": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "properties": {
        "mcp_endpoint": {
          "type": "string"
        },
        "toolsets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        },
        "workdir": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "properties": {
            "active": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "passive": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "memory_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "promotion_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "watch",
            "blocked"
          ]
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "status"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "status": {
                "enum": [
                  "passed",
                  "watch",
                  "blocked"
                ]
              },
              "summary": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
