# Cosmic AI Trading System - Environment Configuration Template
# 宇宙交易系統 - 環境配置模板
#
# Copy this file to .env and fill in your values:
# cp .env.example .env

# ============================================================================
# Environment Selection
# ============================================================================
ENVIRONMENT=development

# ============================================================================
# Core Configuration
# ============================================================================
DEBUG=true
LOG_LEVEL=DEBUG

# ============================================================================
# API Configuration
# ============================================================================
API_DEBUG=true
API_HOST=localhost
API_PORT=8000
API_RATE_LIMIT=unlimited

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_HOST=localhost
DATABASE_NAME=cosmic_ai
DATABASE_PASSWORD=
DATABASE_PATH=data/development.db
DATABASE_PORT=5432
DATABASE_SSL=false
DATABASE_TYPE=sqlite
DATABASE_USER=

# ============================================================================
# Cache Configuration
# ============================================================================
CACHE_ENABLED=true
CACHE_HOST=localhost
CACHE_PASSWORD=
CACHE_PORT=6379
CACHE_TYPE=in_memory

# ============================================================================
# SSL/TLS Certificate Configuration
# ============================================================================
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CA_PATH=
SSL_VERIFY=true

# ============================================================================
# Authentication & Security
# ============================================================================
BITGET_API_KEY=
BITGET_SECRET_KEY=
PASSPHRASE=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=

BYBIT_API_KEY=
BYBIT_SECRET=

OKX_API_KEY=
OKX_SECRET_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_USERNAME=
TELEGRAM_TARGET_CHANNEL_ID=
TELEGRAM_USER_ID=

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
API_KEY=

# ============================================================================
# External Services
# ============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
QISKIT_IBM_TOKEN=

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# Trading System Configuration
# ============================================================================
TRADING_MODE=backtest
TRADING_SYMBOLS=BTC,ETH,USDT
TRADING_INTERVAL=1h
TRADING_LEVERAGE=1

# ============================================================================
# Performance & Monitoring
# ============================================================================
ENABLE_METRICS=true
ENABLE_TRACING=true
METRICS_PORT=9090
TRACE_SAMPLE_RATE=0.1

# ============================================================================
# Development Tools
# ============================================================================
RELOAD_ON_CHANGE=true
PROFILE_ENABLED=false
TEST_MODE=false
