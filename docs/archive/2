# 实际交易策略
def trading_strategy(system):
    # 1. 定期扫描全市场
    opportunities = system.find_best_opportunities()

    # 2. 风险控制：只选择高概率机会
    high_prob_opps = [opp for opp in opportunities
                     if opp['breakout_probability'] > 0.7]

    # 3. 仓位管理：根据得分分配资金
    total_score = sum(opp['composite_score'] for opp in high_prob_opps)
    for opp in high_prob_opps:
        position_size = (opp['composite_score'] / total_score) * 100
        print(f"投资 {opp['coin_id']}: {position_size:.1f}% 仓位")

