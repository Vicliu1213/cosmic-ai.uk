    # 计算夏普比率
    sharpe_ratio = self._calculate_sharpe_ratio_advanced()

    # 计算盈利因子
    profit_factor = self._calculate_profit_factor_advanced()

    # 平均盈亏比
    avg_risk_reward = self._calculate_avg_risk_reward()

    return {
        'equity': self.account['equity'],
        'total_profit': self.account['total_profit'],
        'total_return': total_return,
        'annualized_return': annualized_return,
        'win_rate': win_rate,
        'sharpe_ratio': sharpe_ratio,
        'max_drawdown': self.account['max_drawdown'],
        'profit_factor': profit_factor,
        'avg_risk_reward': avg_risk_reward,
        'total_trades': total_trades,
        'winning_trades': winning_trades,
        'losing_trades': self.account['losing_trades']
    }

def _calculate_sharpe_ratio_advanced(self) -> float:
    """计算夏普比率（高级）"""
    if len(self.account['trading_history']) < 20:
        return 0.0

    returns = []
    for trade in list(self.account['trading_history'])[-100:]:
        if trade.get('realized_pnl', 0) != 0:
            roi = trade['realized_pnl'] / trade.get('position_value', 1)
            returns.append(roi)

    if len(returns) < 2:
        return 0.0

    excess_returns = np.array(returns) - 0.02/252
    if np.std(excess_returns) == 0:
        return 0.0

    return np.mean(excess_returns) / np.std(excess_returns) * np.sqrt(252)

def _calculate_profit_factor_advanced(self) -> float:
    """计算盈利因子（高级）"""
    gross_profit = self.account['total_profit']
    gross_loss = abs(self.account['total_loss'])

    if gross_loss == 0:
        return 10.0 if gross_profit > 0 else 0.0

    return gross_profit / gross_loss

def _calculate_avg_risk_reward(self) -> float:
    """计算平均风险回报比"""
    if self.account['total_trades'] == 0:
        return 0.0

    total_rr = 0
    count = 0

    for trade in self.account['trading_history']:
        if 'metadata' in trade and 'risk_reward' in trade['metadata']:
            total_rr += trade['metadata']['risk_reward']
            count += 1

    return total_rr / count if count > 0 else 0.0

def _log_cycle_summary(self, cycle_count: int, cycle_result: Dict, cycle_time: float):
    """记录周期摘要"""
    metrics = self.get_performance_metrics()

    logger.info(f"\\n{'='*60}")
    logger.info(f"🔥 周期 {cycle_count} 摘要")
    logger.info(f"{'='*60}")
    logger.info(f"市场状态: {self.market_state['regime'].value}")
    logger.info(f"量子潜力: {self.market_state['quantum_potential']:.3f}")
    logger.info(f"账户净值: ${metrics['equity']:,.2f}")
    logger.info(f"年化回报: {metrics['annualized_return']*100:+.1f}%")
    logger.info(f"交易胜率: {metrics['win_rate']:.1%}")
    logger.info(f"信号生成: {cycle_result.get('signals_generated', 0)}")
    logger.info(f"交易执行: {cycle_result.get('trades_executed', 0)}")
    logger.info(f"即时利润: ${cycle_result.get('instant_profit', 0):+.2f}")
    logger.info(f"周期时间: {cycle_time:.3f}s")
    logger.info(f"{'='*60}")

