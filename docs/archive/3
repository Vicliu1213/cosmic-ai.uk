    winning_trades = self.account['winning_trades']

    win_rate = winning_trades / total_trades if total_trades > 0 else 0
    total_return = (self.account['equity'] - self.config.INITIAL_CAPITAL) / self.config.INITIAL_CAPITAL

    # 计算年化回报
    days_running = 1  # 简化计算
