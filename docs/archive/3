        json.dump(serializable, f, indent=2, default=str)

async def save_market_state(self, market_state: Dict):
    """保存市场状态"""
    filepath = self.data_dir / f"market_{datetime.now().strftime('%Y%m%d_%H')}.json"

    serializable = self._make_serializable(market_state)

    with open(filepath, 'w') as f:
        json.dump(serializable, f, indent=2, default=str)

async def save_trade_history(self, trades: List[Dict]):
    """保存交易历史"""
