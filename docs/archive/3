def _calculate_quantum_potential(self, prices: List[float],
                               volatilities: List[float]) -> float:
    """计算量子潜力"""
    if len(prices) < 2:
        return 0.0

    # 价格变化率
    price_changes = np.diff(prices) / prices[:-1]

    # 量子相干性指标
    coherence = np.abs(np.fft.fft(price_changes)[1]) / len(price_changes)

    # 波动率调整
    vol_adjustment = np.mean(volatilities) * 10

    # 综合量子潜力
    quantum_potential = coherence * (1 + vol_adjustment) * self.config.QUANTUM_BOOST

    return min(1.0, quantum_potential)

def _calculate_profit_probability(self, market_data: Dict[str, QuantumMarketData]) -> float:
    """计算盈利概率"""
    if not market_data:
        return 0.5

    scores = []

    for data in market_data.values():
        # 动量分数
        momentum_score = abs(data.momentum.get('5m', 0)) * 10

        # 情绪分数
        sentiment_score = data.sentiment.get('fear_greed', 50) / 100

        # 波动率分数
        volatility_score = min(1.0, data.volatility * 20)

        # 综合分数
        score = (momentum_score * 0.4 +
                sentiment_score * 0.3 +
                volatility_score * 0.3)

        scores.append(score)

    return np.mean(scores) if scores else 0.5

def _calculate_market_entropy(self, prices: List[float],
                            volatilities: List[float]) -> float:
    """计算市场熵"""
    if len(prices) < 20:
        return 0.0

    # 价格序列的香农熵
    price_bins = np.histogram(prices, bins=20)[0]
    price_probs = price_bins / price_bins.sum()
    price_entropy = -np.sum(price_probs * np.log2(price_probs + 1e-10))

    # 波动率熵
    vol_bins = np.histogram(volatilities, bins=10)[0]
    vol_probs = vol_bins / vol_bins.sum()
    vol_entropy = -np.sum(vol_probs * np.log2(vol_probs + 1e-10))

    # 综合熵
    total_entropy = (price_entropy * 0.7 + vol_entropy * 0.3) / np.log2(20)

    return min(1.0, total_entropy)

def _identify_market_regime(self, market_data: Dict[str, QuantumMarketData]) -> MarketRegime:
    """识别市场状态"""
    if not market_data:
        return MarketRegime.UNKNOWN

    # 提取数据
    data = list(market_data.values())[0]  # 使用第一个交易所的数据

    # 检查波动率
    if data.volatility > 0.08:
        return MarketRegime.HIGH_VOLATILITY
    elif data.volatility < 0.01:
        return MarketRegime.LOW_VOLATILITY

    # 检查动量
    momentum_1h = abs(data.momentum.get('1h', 0))
    if momentum_1h > 0.05:
        return MarketRegime.SUPER_TREND

    # 检查价格变化
    momentum_5m = abs(data.momentum.get('5m', 0))
    if momentum_5m > 0.02 and data.volatility > 0.03:
        return MarketRegime.BREAKOUT

    return MarketRegime.RANGING

def _calculate_momentum_score(self, market_data: Dict[str, QuantumMarketData]) -> float:
    """计算动量分数"""
    if not market_data:
        return 0.0

    momentum_scores = []

    for data in market_data.values():
        # 多时间框架动量
        timeframes = ['1m', '5m', '15m', '1h', '4h']
        weights = [0.1, 0.15, 0.2, 0.25, 0.3]

        total_score = 0
        for tf, weight in zip(timeframes, weights):
            momentum = data.momentum.get(tf, 0)
            total_score += abs(momentum) * weight * 10

        momentum_scores.append(total_score)

    return np.mean(momentum_scores) if momentum_scores else 0.0

