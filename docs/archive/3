    """停止监控"""
    self.running = False
    logger.info("📊 实时监控系统停止")

def update(self, data: Dict):
    """更新监控数据"""
    if not self.running:
        return

    try:
        self.metrics = {
            'timestamp': datetime.now(),
            'cycle': data.get('cycle', 0),
            'account_equity': data.get('account', {}).get('equity', 0),
            'market_regime': data.get('market_state', {}).get('regime', 'unknown'),
            'quantum_potential': data.get('market_state', {}).get('quantum_potential', 0),
            'trades_executed': data.get('cycle_result', {}).get('trades_executed', 0),
            'instant_profit': data.get('cycle_result', {}).get('instant_profit', 0)
        }

        # 检查异常
        self._check_anomalies()

    except Exception as e:
        logger.error(f"监控更新错误: {e}")

def _check_anomalies(self):
    """检查异常"""
    equity = self.metrics.get('account_equity', 0)

    # 检查资金异常下降
    if 'last_equity' in self.metrics:
        change = (equity - self.metrics['last_equity']) / self.metrics['last_equity']

        if change < -0.05:  # 下跌超过5%
            alert = {
                'type': 'equity_drop',
                'severity': 'high',
                'message': f"资金异常下降: {change:.1%}",
                'timestamp': datetime.now()
            }
            self.alerts.append(alert)
            logger.warning(f"⚠️ 资金异常下降: {change:.1%}")

    self.metrics['last_equity'] = equity

    # 检查交易频率异常
    trades_executed = self.metrics.get('trades_executed', 0)
    if trades_executed > 20:  # 单周期交易过多
        alert = {
            'type': 'high_frequency',
            'severity': 'medium',
            'message': f"交易频率异常: {trades_executed}笔/周期",
            'timestamp': datetime.now()
        }
        self.alerts.append(alert)

