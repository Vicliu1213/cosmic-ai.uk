    """优化周期"""
    try:
        # 1. 分析周期结果
        win_rate = self.account['winning_trades'] / max(1, self.account['total_trades'])
        avg_profit = self.account['total_profit'] / max(1, self.account['winning_trades'])
        avg_loss = abs(self.account['total_loss']) / max(1, self.account['losing_trades'])

        # 2. 动态调整
