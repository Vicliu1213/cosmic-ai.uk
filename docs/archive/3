async def _adjust_engine_weights(self, cycle_result: Dict):
    """调整引擎权重"""
    # 分析各引擎表现
    engine_performance = {}

    for trade in self.account['trading_history']:
        engine = trade.get('engine', '')
        profit = trade.get('realized_pnl', 0)

        if engine not in engine_performance:
            engine_performance[engine] = {'total': 0, 'count': 0}

        engine_performance[engine]['total'] += profit
        engine_performance[engine]['count'] += 1

    # 调整引擎使用频率
    for engine_name, perf in engine_performance.items():
        if perf['count'] > 5:
            avg_profit = perf['total'] / perf['count']

            if engine_name in self.engines:
                # 调整引擎参数
                if hasattr(self.engines[engine_name], 'adjust_aggression'):
                    if avg_profit > 0:
                        self.engines[engine_name].adjust_aggression(1.1)
                    else:
                        self.engines[engine_name].adjust_aggression(0.9)

