def quantum_encode(self, data):
    # 将数据编码为128维量子态
    qubits = []
    for i in range(128):
        angle = data['features'][i % len(data['features'])] * np.pi
        qubits.append(QuantumVariable(angle))
    return QuantumArray(qubits)

