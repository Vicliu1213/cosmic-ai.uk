import numpy as np
from scipy.stats import skew, kurtosis

class SingularityStrengthCalculator:
    """
    從概率雲中計算「奇點強度」。
    真正的奇點不僅是價格移動，而且是現有統計分佈的「異常」。
    """
    @staticmethod
    def calculate(probability_cloud, historical_returns):
        """
        計算奇點強度指數 (0-1之間)
        """
        # 1. 提取概率雲的統計特性
        cloud_mean = np.mean(probability_cloud)
        cloud_std = np.std(probability_cloud)
        cloud_skew = skew(probability_cloud)
        cloud_kurt = kurtosis(probability_cloud)

        # 2. 與歷史統計特性比較
        historical_std = np.std(historical_returns)
        historical_skew = skew(historical_returns)
        historical_kurt = kurtosis(historical_returns)

        # 3. 計算「異常分數」
        # 標準差異常：預期波動率遠高於歷史水平
        std_anomaly = max(0, (cloud_std - historical_std) / historical_std)
        # 偏度異常：極端的不對稱（預期有大規模的單邊移動）
        skew_anomaly = abs(cloud_skew - historical_skew)
        # 峰度異常：「肥尾」效應極端顯著（預期發生黑天鵝事件）
        kurt_anomaly = max(0, (cloud_kurt - historical_kurt) / historical_kurt)

        # 4. 綜合奇點強度指數（可以調整權重）
        singularity_strength = (
            0.5 * np.tanh(std_anomaly) +    # 使用tanh防止某項異常主導一切
            0.3 * np.tanh(skew_anomaly) +
            0.2 * np.tanh(kurt_anomaly)
        )

        # 確保結果在0-1之間
        return min(max(singularity_strength, 0.0), 1.0)

