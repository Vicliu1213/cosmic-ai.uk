from collections import deque

class TickProcessor:
    def __init__(self, ports=[8888, 8889, 8890]):
        self.buffers = {port: deque(maxlen=100000) for port in ports}
        self.sockets = []
        for port in ports:
            sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            sock.bind(('0.0.0.0', port))
            sock.settimeout(0.001)
            self.sockets.append(sock)

    def process_ticks(self):
        while True:
            for sock in self.sockets:
                try:
                    data, addr = sock.recvfrom(1024)
                    # 解析納秒級數據包結構
                    exchange_id = struct.unpack('B', data[0:1])[0]
                    timestamp = struct.unpack('Q', data[1:9])[0]  # 納秒時間戳
                    price = struct.unpack('d', data[9:17])[0]
                    volume = struct.unpack('I', data[17:21])[0]
