{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Engine Configuration Schema",
  "type": "object",
  "required": ["engine", "quantum", "classical"],
  "properties": {
    "engine": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["hybrid", "quantum", "classical"] },
        "enabled": { "type": "boolean" },
        "version": { "type": "string" }
      }
    },
    "quantum": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "max_qubits": { "type": "integer", "minimum": 1 },
        "optimization": { "type": "string" }
      }
    },
    "classical": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "threads": { "type": "integer", "minimum": 1 },
        "optimization": { "type": "string" }
      }
    }
  }
}
