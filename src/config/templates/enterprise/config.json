{
  "system": {
    "name": "Cosmic AI - Enterprise",
    "version": "1.0.0",
    "environment": "production"
  },
  "engine": {
    "type": "hybrid",
    "enabled": true,
    "optimization": "maximum"
  },
  "database": {
    "type": "postgresql",
    "pool_size": 20,
    "ssl": true
  },
  "cache": {
    "type": "redis",
    "cluster": true,
    "ttl": 3600
  },
  "api": {
    "host": "api.example.com",
    "port": 443,
    "rate_limit": 1000,
    "authentication": "oauth2"
  },
  "monitoring": {
    "enabled": true,
    "metrics": true,
    "tracing": true
  },
  "logging": {
    "level": "INFO",
    "output": ["file", "elasticsearch"]
  }
}
