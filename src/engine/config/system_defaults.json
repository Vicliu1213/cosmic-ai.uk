{
  "system": {
    "name": "Cosmic AI Trading System",
    "version": "1.0.0",
    "environment": "production"
  },
  "performance": {
    "max_concurrent_trades": 100,
    "max_queue_size": 10000,
    "timeout_seconds": 30,
    "retry_attempts": 3
  },
  "trading": {
    "default_symbol": "BTC/USDT",
    "default_interval": "5m",
    "position_size": 1.0,
    "stop_loss_percent": 2.0,
    "take_profit_percent": 5.0
  },
  "risk_management": {
    "max_drawdown_percent": 10.0,
    "daily_loss_limit": 5.0,
    "max_leverage": 10.0,
    "position_limit": 5
  },
  "notification": {
    "enabled": true,
    "channels": ["email", "telegram", "webhook"],
    "alert_types": ["trade_created", "trade_closed", "error", "warning"]
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "output": ["console", "file"],
    "file_path": "logs/",
    "retention_days": 30
  }
}
