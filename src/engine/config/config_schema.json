{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cosmic AI Engine Configuration Schema",
  "type": "object",
  "required": ["engine", "data_layer"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "engine_type": {
          "type": "string",
          "enum": ["hybrid", "quantum", "classical"]
        },
        "deployment_date": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "engine": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3
        },
        "type": {
          "type": "string",
          "enum": ["hybrid", "quantum", "classical"]
        },
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": ["development", "staging", "production"]
        }
      }
    },
    "data_layer": {
      "type": "object",
      "properties": {
        "cache": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["redis", "memcached", "in_memory"]
            },
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "database": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["postgresql", "mysql", "mongodb"]
            },
            "enabled": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "api_integrations": {
      "type": "object",
      "properties": {
        "gemini": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "vertex_ai": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
